# GitHub token with: repo (read/write issues, push), workflow
# Use a fine-grained PAT (issues+contents+workflows on the 12 infra repos)
# OR a classic PAT with `repo` scope.
GITHUB_TOKEN=

# Where to clone repos to during processing (default: /tmp/portal-tui)
PORTAL_WORK_DIR=/tmp/portal-tui

# Where to write audit logs (default: ~/.portal-tui/audit)
PORTAL_AUDIT_DIR=

# Paths to required CLIs (default: looks in PATH)
CLAUDE_BIN=claude
TOFU_BIN=tofu
GIT_BIN=git

# Max turns for `claude -p` per request
CLAUDE_MAX_TURNS=20
