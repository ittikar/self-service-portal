# NextAuth
AUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# GitHub OAuth (for user sign-in) — register at https://github.com/settings/developers
# Callback URL: http://localhost:3000/api/auth/callback/github
# Scopes: read:user user:email read:org  (set in code)
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Restrict sign-in to members of this GitHub org
ALLOWED_GITHUB_ORG=ittikar

# GitHub App (for opening Issues in infra repos)
# Register at https://github.com/organizations/ittikar/settings/apps
# Permissions: Issues R/W, Metadata R
# Install on the 8 infra repos
GITHUB_APP_ID=
GITHUB_APP_INSTALLATION_ID=
GITHUB_APP_PRIVATE_KEY=

# Worklap (optional — if set, portal also creates a task on submit)
# QA: https://wlqa.testingmonkey.com/api
# Prod: https://api.worklap.com
WORKLAP_API_URL=
WORKLAP_EMAIL=
WORKLAP_PASSWORD=
WORKLAP_PROJECT_UUID=
WORKLAP_WORK_TYPE_UUID=
WORKLAP_WORK_STATUS_UUID=
WORKLAP_ASSIGNEE_USER_UUID=
